{
  "name": "chrisltd-com",
  "version": "1.0.0",
  "description": "chrisltd.com — Eleventy static site + visual regression harness",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "eleventy",
    "start": "BUILD_DRAFTS=1 eleventy --serve --port=8080",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visual:baseline": "node tests/visual/snap.mjs --mode=baseline",
    "visual:check": "node tests/visual/snap.mjs --mode=check"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@shopify/prettier-plugin-liquid": "^1.10.3",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "prismjs": "^1.30.0",
    "sass": "^1.101.0"
  }
}
